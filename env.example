# Helvetiforma API Configuration
# Copy this file to .env.local and update the values

# Strapi Configuration (Backup/Original)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# WordPress Configuration (Native WordPress Posts)
NEXT_PUBLIC_WORDPRESS_URL=https://api.helvetiforma.ch

# API Source Control
# Set to 'true' to use WordPress as primary API
NEXT_PUBLIC_USE_WORDPRESS=false

# Fallback Configuration
# Set to 'true' to fallback to Strapi if WordPress fails
NEXT_PUBLIC_FALLBACK_TO_STRAPI=true

# Development Settings
NODE_ENV=development

