{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "env": {
    "NEXT_PUBLIC_WORDPRESS_URL": "https://helvetiforma.ch",
    "NEXT_PUBLIC_USE_WORDPRESS": "true",
    "NEXT_PUBLIC_FALLBACK_TO_STRAPI": "false"
  },
  "routes": [
    {
      "src": "/api-control",
      "dest": "/api-control"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/admin/$1"
    },
    {
      "src": "/formations/(.*)",
      "dest": "/formations/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
} 